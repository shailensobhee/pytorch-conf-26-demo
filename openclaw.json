{
  "gateway": {
    "auth": {
      "token": "claw123"
    },
    "mode": "local"
  },
  "meta": {
    "lastTouchedVersion": "2026.4.14",
    "lastTouchedAt": "2026-04-17T10:31:13.064Z"
  },
  "messages": {
    "queue": {
      "mode": "steer+backlog",
      "cap": 1000,
      "drop": "summarize"
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "vllm/google/gemma-4-31B-it"
      },
      "imageModel": {
        "primary": "vllm/google/gemma-4-31B-it"
      },
      "pdfModel": {
        "primary": "vllm/google/gemma-4-31B-it"
      }
    },
    "list": [
      {
        "id": "orchestrator",
        "workspace": "~/.openclaw/agents/orchestrator"
      },
      {
        "id": "transcriber",
        "workspace": "~/.openclaw/agents/transcriber"
      },
      {
        "id": "doc-scout",
        "workspace": "~/.openclaw/agents/doc-scout"
      },
      {
        "id": "journalist",
        "workspace": "~/.openclaw/agents/journalist",
        "thinkingDefault": "high",
        "reasoningDefault": "off"
      }
    ]
  },
  "models": {
    "providers": {
      "vllm": {
        "baseUrl": "http://localhost:8001/v1",
        "apiKey": "local-vllm",
        "api": "openai-completions",
        "models": [
          {
            "id": "google/gemma-4-31B-it",
            "name": "Gemma-4-Vision",
            "input": [
              "text",
              "image"
            ],
            "compat": {
              "supportsUsageInStreaming": true
            }
          }
        ]
      }
    }
  },
  "tools": {
    "allow": [
      "group:fs",
      "exec",
      "sessions_spawn",
      "subagents"
    ],
    "exec": {
      "ask": "off",
      "security": "full"
    }
  },
  "plugins": {
    "entries": {
      "vllm": {
        "enabled": true
      }
    }
  }
}
